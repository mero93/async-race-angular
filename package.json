{
  "name": "async-race-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "npx prettier . --write",
    "ci:format": "npx prettier --check",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.18.0",
  "dependencies": {
    "@angular/cdk": "22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@ngrx/signals": "^21.1.1",
    "@spartan-ng/brain": "^1.1.1",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/schematics": "^22.1.0",
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@spartan-ng/cli": "^1.1.1",
    "@tailwindcss/postcss": "^4.1.12",
    "angular-eslint": "22.1.0",
    "eslint": "^10.6.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{html,scss,json,md}": [
      "prettier --write"
    ]
  }
